# DATABASE - MYSQL
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

DB_CART_URL=jdbc:mysql://mysql:3306/techstore_cart?createDatabaseIfNotExist=true
DB_IDENTITY_URL=jdbc:mysql://mysql:3306/techstore_identity?createDatabaseIfNotExist=true
DB_ORDER_URL=jdbc:mysql://mysql:3306/techstore_order?createDatabaseIfNotExist=true
DB_PRODUCT_URL=jdbc:mysql://mysql:3306/techstore_product?createDatabaseIfNotExist=true
DB_REVIEW_URL=jdbc:mysql://mysql:3306/techstore_review?createDatabaseIfNotExist=true
DB_USER_URL=jdbc:mysql://mysql:3306/techstore_user?createDatabaseIfNotExist=true
DB_WAREHOUSE_URL=jdbc:mysql://mysql:3306/techstore_warehouse?createDatabaseIfNotExist=true
DB_QUIZGAME_URL=jdbc:mysql://mysql:3306/techstore_quizgame?createDatabaseIfNotExist=true

# REDIS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# MONGODB
MONGO_NOTIFICATION_URI=mongodb://<user>:<password>@mongodb:27017/techstore-notification
MONGO_FILE_URI=mongodb://<user>:<password>@mongodb:27017/techstore-file
MONGO_CHAT_URI=mongodb://<user>:<password>@mongodb:27017/techstore-chat
MONGO_CHATBOT_URI=mongodb://<user>:<password>@mongodb:27017/techstore-chatbot

# SECURITY / SESSION
SESSION_KEY=your_session_key

# FILE STORAGE
FILE_STORAGE_DIR=/app/uploads
FILE_DOWNLOAD_PREFIX=http://api-gateway:8888/techstore/api/v1/file/media/download/

# KAFKA
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_NOTIFICATION_GROUP_ID=notification-group

# SOCKET
CHAT_SERVICE_SOCKET_PORT=8099
CHAT_SERVICE_SOCKET_ORIGIN=*

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT
JWT_SIGNER_KEY=your_jwt_secret
JWT_VALID_DURATION=36000
JWT_REFRESH_DURATION=604800

# MAIL
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email
MAIL_PASSWORD=your_email_password

# GEMINI API
GEMINI_API_KEY_1=your_key_1
GEMINI_API_KEY_2=your_key_2
GEMINI_API_KEY_3=your_key_3
GEMINI_API_KEY_4=your_key_4
GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent

# SHIPPING (GHN)
GHN_BASE_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_TOKEN=your_token
GHN_PROVINCE_ID=xxx
GHN_DISTRICT_ID=xxx
GHN_WARD_CODE=xxx

# ADMIN DEFAULT
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# PAYMENT (VNPAY)
VNP_TMN_CODE=your_tmn_code
VNP_SECRET_KEY=your_secret_key